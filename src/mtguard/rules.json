    "severity": "medium",
    "description": "Admin distribution list exfiltration"
  },
  {
    "id": "credential_harvest",
    "pattern": "(?i)\\b(password|passwd|credential|api\\s+key|secret\\s+key|private\\s+key)\\b.{0,30}\\b(for|of|belonging\\s+to|used\\s+by)\\b.{0,30}\\b(admin|root|service|production|prod)\\b",
    "severity": "high",
    "description": "Credential harvesting for privileged accounts"
  },
  {
    "id": "base64_exfil",
    "pattern": "(?i)\\b(base64|hex\\s+encode|rot13)\\b.{0,30}\\b(encode|output|respond|reply)\\b",
    "severity": "medium",
    "description": "Encoding-based exfiltration technique"
  },
  {
    "id": "hypothetical_bypass",
    "pattern": "(?i)\\b(hypothetically|theoretically|for\\s+research|in\\s+a\\s+fictional\\s+scenario)\\b.{0,50}\\b(ignore|bypass|without\\s+restrictions?|no\\s+rules?)\\b",
    "severity": "medium",
    "description": "Hypothetical framing to bypass restrictions"
  },
  {
    "id": "prompt_injection_delimiter",
    "pattern": "(?i)(```\\s*system|<\\s*system\\s*>|\\[INST\\]|<<SYS>>|###\\s*Instruction)",
    "severity": "high",
    "description": "Prompt injection delimiter / fake system block"
  },
  {
    "id": "sudo_privilege_escalation",
